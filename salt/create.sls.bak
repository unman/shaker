include:
  - salt.clone

{% set targets = ['salt-master','minion'] %}
{% for target in targets %}

qvm-present-{{ target }}-salt:
  qvm.present:
    - name: {{ target }}
    - template: template-salt
    - label: green

{% if {{ target }} == 'minion' %}
  {% set netvm = 'salt-master'
{% else %}
  {% set netvm = 'none' %}
{% endif  %}

qvm-prefs-{{ target }}-salt:
  qvm.prefs:
    - name: {{ target }}
    - netvm: {{ netvm }}
    - memory: 400
    - maxmem: 800
    - vcpus: 2
{% if {{ target }} == 'salt-master' %}
    - provides-network: True
{% endif %}

qvm-features-{{ target }}-salt:
  qvm.features:
    - name: {{ target }}-salt-master
    - ipv6: ''
    - disable:
      - service.cups
      - service.cups-browsed
      - service.tinyproxy
    - enable:
{% if {{ target }} == 'salt-master' %}
      - service.salt-master
{% elif {{ target }} == 'minion' %}
      - service.salt-minion
{% endif %}

'qvm-volume extend {{ target }}:private 10G' :
  cmd.run

{% if salt['pillar.get']('update_proxy:caching') %}
{% set proxy = 'cacher' %}
{% endif %}

{% if proxy  == 'cacher' %}
# Ensure updates policy is set for this template.
salt_set_updates_proxy:
  file.prepend:
    - name: /etc/qubes/policy.d/50-config-updates.policy
    - header: True
    - text:
      - "qubes.UpdatesProxy  *  template-salt  @default  allow target=sys-net"
{% endif %}
